<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #eef1f8;"
            xmlns="http://javafx.com/javafx/20.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="viewmodel.SignUpController">
    <children>
        <VBox alignment="CENTER" spacing="12.0"
              layoutX="250.0" layoutY="80.0" prefWidth="400.0">

            <Label text="AcademicTrack" style="-fx-font-size: 14px; -fx-text-fill: #666;">
                <font><Font name="System Italic" size="14.0"/></font>
            </Label>
            <Label text="Create New Account"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #222;">
                <VBox.margin><Insets bottom="10.0"/></VBox.margin>
            </Label>

            <Label text="Username" style="-fx-font-weight: bold;" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"/>
            <TextField fx:id="usernameField" promptText="Choose a username"
                       style="-fx-border-color: #bbb; -fx-border-radius: 4; -fx-background-radius: 4;"
                       maxWidth="1.7976931348623157E308"/>

            <Label text="Email" style="-fx-font-weight: bold;" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"/>
            <TextField fx:id="emailField" promptText="email@domain.edu"
                       style="-fx-border-color: #bbb; -fx-border-radius: 4; -fx-background-radius: 4;"
                       maxWidth="1.7976931348623157E308"/>

            <Label text="Password" style="-fx-font-weight: bold;" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"/>
            <PasswordField fx:id="passwordField" promptText="Create a password"
                           style="-fx-border-color: #bbb; -fx-border-radius: 4; -fx-background-radius: 4;"
                           maxWidth="1.7976931348623157E308"/>

            <Label text="Confirm Password" style="-fx-font-weight: bold;" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password"
                           style="-fx-border-color: #bbb; -fx-border-radius: 4; -fx-background-radius: 4;"
                           maxWidth="1.7976931348623157E308"/>

            <Label fx:id="statusLabel" text="" wrapText="true" maxWidth="400.0"
                   style="-fx-text-fill: #cc0000; -fx-font-size: 12px;">
                <VBox.margin><Insets top="4.0"/></VBox.margin>
            </Label>

            <Button text="Create Account" onAction="#createNewAccount"
                    maxWidth="1.7976931348623157E308" prefHeight="40.0"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-width: 0; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.35), 6, 0, 0, 2); -fx-cursor: hand;">
                <VBox.margin><Insets top="8.0"/></VBox.margin>
            </Button>

            <Button text="Back to Login" onAction="#goBack"
                    maxWidth="1.7976931348623157E308" prefHeight="36.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #2563eb; -fx-font-size: 13px; -fx-border-color: #2563eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </children>
</AnchorPane>
