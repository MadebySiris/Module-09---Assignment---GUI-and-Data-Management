<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootpane"
           xmlns="http://javafx.com/javafx/20.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="viewmodel.LoginController">

    <!-- Centered login card -->
    <VBox alignment="CENTER" spacing="0"
          maxWidth="380.0"
          style="-fx-background-color: rgba(255,255,255,0.92);
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 24, 0, 0, 6);
                 -fx-padding: 0;">

        <!-- Header band -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-background-color: #1a3a6b;
                     -fx-background-radius: 16 16 0 0;
                     -fx-padding: 28 32 24 32;">
            <Label text="AcademicTrack"
                   style="-fx-text-fill: #7dd3fc; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 2;">
                <font><Font name="System Bold" size="13.0"/></font>
            </Label>
            <Label text="Student Registry"
                   style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="26.0"/></font>
            </Label>
            <Label text="Sign in to your account"
                   style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px;"/>
        </VBox>

        <!-- Form body -->
        <VBox spacing="14" style="-fx-padding: 28 32 32 32; -fx-background-color: transparent;">

            <!-- Username -->
            <VBox spacing="5">
                <Label text="Username"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="usernameTextField"
                           promptText="Enter your username"
                           style="-fx-background-color: #f9fafb;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 10 12;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #111827;
                                  -fx-prompt-text-fill: #9ca3af;">
                    <font><Font size="13.0"/></font>
                </TextField>
            </VBox>

            <!-- Password -->
            <VBox spacing="5">
                <Label text="Password"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               style="-fx-background-color: #f9fafb;
                                      -fx-border-color: #d1d5db;
                                      -fx-border-width: 1;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 12;
                                      -fx-font-size: 13px;
                                      -fx-text-fill: #111827;
                                      -fx-prompt-text-fill: #9ca3af;">
                    <font><Font size="13.0"/></font>
                </PasswordField>
            </VBox>

            <!-- Error label -->
            <Label fx:id="errorLabel" text="" wrapText="true" maxWidth="316"
                   style="-fx-text-fill: #dc2626; -fx-font-size: 12px;"/>

            <!-- Login button -->
            <Button fx:id="loginBtn" text="Sign In" onAction="#login"
                    maxWidth="1.7976931348623157E308" prefHeight="44.0"
                    style="-fx-background-color: #2563eb;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 14px;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.4), 6, 0, 0, 2);">
                <VBox.margin><Insets top="4.0"/></VBox.margin>
            </Button>

            <!-- Divider -->
            <VBox alignment="CENTER" spacing="0">
                <VBox.margin><Insets top="4.0" bottom="4.0"/></VBox.margin>
                <Separator style="-fx-background-color: #e5e7eb;"/>
            </VBox>

            <!-- Sign up button -->
            <Button fx:id="signUpButton" text="Create an Account" onAction="#signUp"
                    maxWidth="1.7976931348623157E308" prefHeight="40.0"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #2563eb;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-border-color: #2563eb;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;"/>

        </VBox>
    </VBox>
</StackPane>
